# =============================================================================
# Production environment configuration
# Copy to .env and fill in real values before deploying.
# NEVER commit .env — it is gitignored.
#
# Generate secrets:   openssl rand -hex 32
# Docs: docs/SECRET_ROTATION.md
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Agent Orchestrator"
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Security ──────────────────────────────────────────────────────────────────
# Bootstrap admin API key — rotate every 90 days (see docs/SECRET_ROTATION.md)
# Generate: openssl rand -hex 32
API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

REQUIRE_API_KEY=true

# Separate token for Prometheus /metrics scraping
METRICS_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# HMAC secret for validating incoming Alertmanager webhooks
WEBHOOK_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
WEBHOOK_REQUIRE_AUTH=true
# HMAC secret for signing outbound run-event webhooks
OUTBOUND_WEBHOOK_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# CORS — restrict to your production domain(s)
CORS_ORIGINS=https://api.yourdomain.com,https://dashboard.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Use PostgreSQL in production (never SQLite)
DATABASE_URL=postgresql://orchestrator:CHANGE_ME@postgres-service:5432/orchestrator

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=bedrock
LLM_MODEL=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1
# If using IAM roles (EKS IRSA) — leave these blank
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: OpenAI as backup provider (switch LLM_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Default IP-based limit for unauthenticated endpoints.
# Authenticated requests use role-based tiers (viewer: 30, operator: 100, admin: 500)
RATE_LIMIT_PER_MINUTE=60

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# ── Graceful Shutdown ─────────────────────────────────────────────────────────
# Should match terminationGracePeriodSeconds in k8s/deployment.yaml
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=45

# ── Observability ─────────────────────────────────────────────────────────────
# OpenTelemetry traces — send to Jaeger or any OTLP-compatible backend
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ── Alertmanager Notification Channels ───────────────────────────────────────
# PagerDuty — Events API v1 service key (critical alerts)
PAGERDUTY_SERVICE_KEY=CHANGE_ME

# SMTP — for email notifications (ops + finance teams)
SMTP_SMARTHOST=smtp.example.com:587
SMTP_FROM=alerts@yourdomain.com
SMTP_AUTH_USERNAME=alerts@yourdomain.com
SMTP_AUTH_PASSWORD=CHANGE_ME

ALERT_EMAIL_OPS=ops@yourdomain.com
ALERT_EMAIL_FINANCE=finance@yourdomain.com

# Generic webhook — Slack, Teams, OpsGenie, or any HTTP endpoint
ALERTMANAGER_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Optional: Redis run queue ─────────────────────────────────────────────────
# Uncomment to enable durable async run queue (requires Redis)
# RUN_QUEUE_URL=redis://redis:6379/0

# ── Optional: ChromaDB RAG ────────────────────────────────────────────────────
# Uncomment and mount a PVC at /app/chroma for persistent vector storage
# CHROMA_PERSIST_DIRECTORY=/app/chroma

# ── Optional: LLM routing ─────────────────────────────────────────────────────
# USE_LLM_ROUTING=true
# LLM_ROUTING_TIMEOUT=10

# ── DEX Platform ──────────────────────────────────────────────────────────────
DEX_SCAN_INTERVAL_MINUTES=5
DEX_SCORE_ALERT_THRESHOLD=70
DEX_SCORE_CRITICAL_THRESHOLD=50
DEX_SELF_HEALING_ENABLED=false
# DEX_TICKET_WEBHOOK_URL=https://your-servicenow-instance/api/now/table/incident

