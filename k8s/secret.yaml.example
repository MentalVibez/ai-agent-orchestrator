apiVersion: v1
kind: Secret
metadata:
  name: orchestrator-secrets
  labels:
    app: ai-agent-orchestrator
type: Opaque
stringData:
  # Required: bootstrap admin API key (min 32 chars recommended)
  API_KEY: "your-secret-api-key-here"
  # Required: PostgreSQL connection string. SQLite is NOT supported in K8s.
  DATABASE_URL: "postgresql://orchestrator:changeme@postgres-service:5432/orchestrator"
  # Required for Bedrock provider
  AWS_ACCESS_KEY_ID: "your-aws-access-key-id"
  AWS_SECRET_ACCESS_KEY: "your-aws-secret-access-key"
  # Strongly recommended in production
  METRICS_TOKEN: "your-metrics-scrape-token-here"
  WEBHOOK_SECRET: "your-webhook-hmac-secret-here"
  # Optional
  OPENAI_API_KEY: ""

